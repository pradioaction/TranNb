# ==============================================
# 1. Python 编译文件（你要求必须屏蔽 .pyc）
# ==============================================
__pycache__/
*.py[cod]          # .pyc, .pyo, .pyd
*$py.class
*.so
*.dll

# ==============================================
# 2. Trae AI IDE 相关（你要求必须屏蔽）
# ==============================================
# Trae 主配置目录
.trae/
# Trae 规则/指令文件
.instructions.md
.prompt.md
# Trae 工作区/缓存/临时文件
.trae.yml
.trae.yaml
.trae.log
.trae.cache/
.trae-temp/
# Trae 技能/模块相关
*.trae-skill
*.trae-module
# 其他 Trae 生成文件
.trae.history
.trae.state

# ==============================================
# 3. 虚拟环境 & 依赖
# ==============================================
venv/
.venv/
env/
ENV/
env.bak/
venv.bak/
*.egg-info/
.eggs/
dist/
build/
*.egg
*.whl

# ==============================================
# 4. 环境变量 & 密钥（安全）
# ==============================================
.env
.env.local
.env.development
.env.production
.envrc
.secrets
*.key
*.pem
*.cert

# ==============================================
# 5. IDE / 编辑器
# ==============================================
# PyCharm / IntelliJ
.idea/
*.iml
*.iws
*.ipr

# VS Code
.vscode/
!.vscode/extensions.json
!.vscode/settings.json

# ==============================================
# 6. 日志、缓存、测试、临时文件
# ==============================================
*.log
logs/
log/
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.tox/
.nox/
tmp/
temp/
*.tmp
*.bak
*.swp
*.swo

# ==============================================
# 7. 系统文件
# ==============================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db